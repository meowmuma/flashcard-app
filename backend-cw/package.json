{
  "name": "jamman-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create jamman-db",
    "db:migrate:local": "wrangler d1 execute jamman-db --local --file=schema.sql",
    "db:migrate:prod": "wrangler d1 execute jamman-db --file=schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260307.1",
    "typescript": "^5.9.3",
    "wrangler": "^3.114.17"
  }
}
